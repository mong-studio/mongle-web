
# dev: 비워두면 상대경로(/api/v1) + vite proxy로 same-origin 호출 (권장).
# 호스트를 직접 지정하려면 앱을 여는 호스트와 동일해야 한다(예: localhost로 열면 localhost:8000).
# localhost↔127.0.0.1처럼 호스트가 다르면 cross-site가 되어 SameSite=Lax refresh 쿠키가 막힌다.
VITE_API_BASE=

VITE_KAKAO_JS_KEY=
VITE_KAKAO_CLIENT_ID=
VITE_KAKAO_REDIRECT_URI=http://localhost:5173/oauth/kakao/callback
