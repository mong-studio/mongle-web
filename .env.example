# ────────────────────────────────────────
# mongle-server (Django) 주소
# 로컬: http://127.0.0.1:8000
# 배포: 실제 서버 주소로 교체
# ────────────────────────────────────────
VITE_API_BASE=http://127.0.0.1:8000

# ────────────────────────────────────────
# Godot 빌드 경로 (기본값: /godot/index.html)
# ────────────────────────────────────────
VITE_GODOT_EXPORT_PATH=/godot/index.html

# ────────────────────────────────────────
# 카카오 JavaScript 앱 키 (선택)
# 설정 시 피드 "공유하기 > 카카오톡"이 카카오 SDK로 동작.
# 미설정 시 OS 네이티브 공유 시트 → 링크 복사로 자동 폴백.
# https://developers.kakao.com → 내 애플리케이션 > 앱 키 > JavaScript 키
# ────────────────────────────────────────
VITE_KAKAO_JS_KEY=
